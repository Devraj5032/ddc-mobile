{
  "expo": {
    "name": "Drink Now",
    "slug": "drink-now",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#5224B5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.drinknow.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5224B5",
        "foregroundImage": "./assets/logo.png"
      },
      "package": "com.drinknow.app"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-asset"
    ]
  }
}
